# ============================================================================
# IBM watsonx.ai Credentials
# ============================================================================
# Get your API key from: https://cloud.ibm.com/iam/apikeys
WATSONX_APIKEY=your_apikey_here
WATSONX_URL=https://us-south.ml.cloud.ibm.com
WATSONX_PROJECT_ID=your_project_id_here
WATSONX_MODEL_ID=ibm/granite-3-0-8b-instruct

# ============================================================================
# Local Ollama Configuration
# ============================================================================
# Ollama server URL (use host.docker.internal when running in Docker)
OLLAMA_BASE_URL=http://localhost:11434

# Models to use (ensure these are pulled: ollama pull <model>)
CODE_MODEL=granite-code:8b
REASONING_MODEL=mistral-nemo:12b
EMBEDDING_MODEL=mxbai-embed-large

# ============================================================================
# Application Configuration
# ============================================================================
# Path to repository to monitor (relative or absolute)
REPO_PATH=../

# Path to ChromaDB vector store
CHROMA_DB_PATH=./chroma_db

# Path to compliance reports output
REPORTS_DIR=./compliance-reports

# ============================================================================
# Processing Configuration
# ============================================================================
# Maximum file size to process (in MB)
MAX_FILE_SIZE_MB=10

# Debounce time for file changes (in seconds)
DEBOUNCE_SECONDS=2

# Maximum content length for analysis (in characters)
MAX_CONTENT_LENGTH=4000

# Number of RAG results to retrieve
RAG_TOP_K=5

# Text chunking configuration
CHUNK_SIZE=1000
CHUNK_OVERLAP=200

# ============================================================================
# Feature Flags
# ============================================================================
# Enable watsonx verification (requires credentials)
ENABLE_WATSONX=true

# Enable async processing (experimental)
ENABLE_ASYNC=false

# Enable caching for incremental updates
ENABLE_CACHING=true

# ============================================================================
# Notification Configuration
# ============================================================================
# Email Notifications
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=compliance-agent@example.com
SMTP_TO=qa-team@example.com,compliance@example.com

# Slack Notifications
ENABLE_SLACK_NOTIFICATIONS=false
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL
