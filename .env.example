# MedTech Compliance Suite — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is in .gitignore.
# ══════════════════════════════════════════════════════════

# ─── Backend Server ────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── JWT Authentication ────────────────────────────────────
# CRITICAL SECURITY: JWT_SECRET is REQUIRED and must be at least 32 characters
# Generate a secure secret with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# 
# PRODUCTION DEPLOYMENT WILL FAIL WITHOUT A PROPER JWT_SECRET
JWT_SECRET=REPLACE_THIS_WITH_A_SECURE_RANDOM_SECRET_AT_LEAST_32_CHARACTERS_LONG
JWT_EXPIRY=8h

# ─── Database ──────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DB_PATH=./server/data/compliance.db

# ─── Seed Account Passwords ────────────────────────────────
# SECURITY: These passwords must meet the new requirements:
# - Minimum 12 characters
# - At least one uppercase letter
# - At least one lowercase letter
# - At least one number
# - At least one special character (@$!%*?&)
#
# Default passwords are shown below. CHANGE THESE IN PRODUCTION!
SEED_ADMIN_PASSWORD=Admin123!@#$
SEED_QA_PASSWORD=QaManager123!
SEED_ENGINEER_PASSWORD=Engineer123!
SEED_DEMO_PASSWORD=DemoUser123!
SEED_TJBEST_PASSWORD=TjBest2026!@

# ─── Frontend (Vite) ───────────────────────────────────────
# URL of the backend API (used by the React frontend)
VITE_API_URL=http://localhost:3001

# ─── Frontend Offline / Mock Fallback ──────────────────────
# Only used when the backend is unreachable (e.g. GitHub Pages demo).
# Leave empty to disable offline mock login.
VITE_MOCK_ADMIN_PASSWORD=
VITE_MOCK_QA_PASSWORD=
VITE_MOCK_ENGINEER_PASSWORD=
VITE_MOCK_DEMO_PASSWORD=

# ─── OAuth / SSO (optional) ────────────────────────────────
# Uncomment and fill in for real OAuth provider integration.
# VITE_GOOGLE_CLIENT_ID=
# VITE_GITHUB_CLIENT_ID=
# VITE_MICROSOFT_CLIENT_ID=

# ─── Security Settings ─────────────────────────────────────
# Session timeout in milliseconds (default: 8 hours)
SESSION_TIMEOUT=28800000

# Maximum file upload size in bytes (default: 100MB)
MAX_UPLOAD_SIZE=104857600

# Enable HTTPS in production (requires SSL certificates)
# HTTPS_ENABLED=true
# SSL_KEY_PATH=/path/to/private-key.pem
# SSL_CERT_PATH=/path/to/certificate.pem
