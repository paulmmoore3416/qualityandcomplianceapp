# MedTech Compliance Suite — Environment Configuration
# ══════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# NEVER commit your .env file — it is in .gitignore.
# ══════════════════════════════════════════════════════════

# ─── Backend Server ────────────────────────────────────────
API_PORT=3001
NODE_ENV=development

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173

# ─── JWT Authentication ────────────────────────────────────
# IMPORTANT: Replace with a long, random secret in production.
# Generate one with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=replace-with-your-own-random-secret
JWT_EXPIRY=8h

# ─── Database ──────────────────────────────────────────────
# Path to the SQLite database file (created automatically on first run)
DB_PATH=./server/data/compliance.db

# ─── Seed Account Passwords ────────────────────────────────
# Passwords used when the database is first created.
# If not set, passwords are derived from JWT_SECRET (unique per install).
# Set these for predictable credentials you can share with your team.
SEED_ADMIN_PASSWORD=
SEED_QA_PASSWORD=
SEED_ENGINEER_PASSWORD=
SEED_DEMO_PASSWORD=

# ─── Frontend (Vite) ───────────────────────────────────────
# URL of the backend API (used by the React frontend)
VITE_API_URL=http://localhost:3001

# ─── Frontend Offline / Mock Fallback ──────────────────────
# Only used when the backend is unreachable (e.g. GitHub Pages demo).
# Leave empty to disable offline mock login.
VITE_MOCK_ADMIN_PASSWORD=
VITE_MOCK_QA_PASSWORD=
VITE_MOCK_ENGINEER_PASSWORD=
VITE_MOCK_DEMO_PASSWORD=

# ─── OAuth / SSO (optional) ────────────────────────────────
# Uncomment and fill in for real OAuth provider integration.
# VITE_GOOGLE_CLIENT_ID=
# VITE_GITHUB_CLIENT_ID=
# VITE_MICROSOFT_CLIENT_ID=
